# ========================================================================
# EasyMenu - Environment Variables (example)
# Copy to .env.local and fill in real values. Never commit .env.local.
# ========================================================================

# --- App ---
APP_NAME="EasyMenu"
APP_URL="http://localhost:3100"
NODE_ENV="development"

# --- Database (Postgres) ---
# Local dev:   postgresql://postgres:PASSWORD@localhost:5432/easymenu_db
# Production:  use Neon connection string with pooled + direct
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/easymenu_db"
# DIRECT_URL is used by Prisma migrate when using a pooled DATABASE_URL (Neon, Supabase)
DIRECT_URL="postgresql://postgres:CHANGE_ME@localhost:5432/easymenu_db"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3100"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Realtime (Pusher) ---
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="ap2"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"

# --- WhatsApp (Phase 3 — mock in Phase 1) ---
WHATSAPP_ENABLED="false"
WHATSAPP_PROVIDER="mock"   # mock | meta | twilio
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# --- Stripe (SaaS subscriptions) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- File uploads (Phase 2+) ---
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""
