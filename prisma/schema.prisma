// =====================================================================
// EasyMenu — Prisma schema (Phase 1)
// Multi-tenant: every tenant-scoped table has tenantId + createdAt/updatedAt/deletedAt.
// Future phases will extend this schema; do not break naming conventions.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------- ENUMS ---------------------------------

enum TenantRole {
  OWNER
  MANAGER
  CASHIER
  KITCHEN
  WAITER
  DELIVERY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
}

enum CuisineType {
  RESTAURANT
  CAFE
  FAST_FOOD
  BAKERY
  CLOUD_KITCHEN
  OTHER
}

enum IngredientUnit {
  G
  KG
  ML
  L
  PCS
  DOZEN
}

enum StockMovementReason {
  PURCHASE
  SALE
  WASTAGE
  ADJUSTMENT
  STOCK_TAKE
}

enum WastageReason {
  SPOILAGE
  BREAKAGE
  THEFT
  TRAINING
  OTHER
}

enum AuditAction {
  TENANT_CREATED
  USER_CREATED
  USER_LOGIN
  USER_LOGOUT
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  ONBOARDING_COMPLETED
  IMPERSONATION_STARTED
  IMPERSONATION_ENDED
  TRIAL_EXTENDED
  SUBSCRIPTION_CHANGED
  SETTINGS_UPDATED
  BRANCH_CREATED
  BRANCH_UPDATED
  BRANCH_DELETED
  MENU_CATEGORY_CREATED
  MENU_CATEGORY_UPDATED
  MENU_CATEGORY_DELETED
  MENU_ITEM_CREATED
  MENU_ITEM_UPDATED
  MENU_ITEM_DELETED
  INGREDIENT_CREATED
  INGREDIENT_UPDATED
  INGREDIENT_DELETED
  SUPPLIER_CREATED
  SUPPLIER_UPDATED
  RECIPE_UPDATED
  STOCK_RECEIVED
  STOCK_WASTED
  STOCK_ADJUSTED
}

// ----------------------------- AUTH ----------------------------------
// NextAuth-compatible models (Account, Session, VerificationToken)

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------- USERS ---------------------------------

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null for pure-OAuth users
  isSuperAdmin  Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  accounts    Account[]
  sessions    Session[]
  memberships TenantMembership[]
  auditLogs   AuditLog[]

  @@index([email])
}

// ----------------------------- TENANTS -------------------------------

model Tenant {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  cuisineType CuisineType @default(RESTAURANT)
  contactPhone String?
  logoUrl      String?
  brandColor   String?

  // Tenant-wide config (kept here, not split into Settings table for Phase 1)
  currency     String  @default("PKR")
  timezone     String  @default("Asia/Karachi")
  locale       String  @default("en")
  hasDelivery  Boolean @default(false)
  hasTakeaway  Boolean @default(true)
  acceptCash   Boolean @default(true)
  acceptCard   Boolean @default(false)
  acceptJazzCash Boolean @default(false)
  acceptEasypaisa Boolean @default(false)
  acceptBankTransfer Boolean @default(false)

  onboardedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberships    TenantMembership[]
  subscription   Subscription?
  branches       Branch[]
  menuCategories MenuCategory[]
  menuItems      MenuItem[]
  ingredients    Ingredient[]
  suppliers      Supplier[]
  stockMovements StockMovement[]
  purchases      Purchase[]
  auditLogs      AuditLog[]

  @@index([slug])
  @@index([deletedAt])
}

// ----------------------------- BRANCHES ------------------------------

model Branch {
  id        String  @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  phone     String?
  isPrimary Boolean @default(false)
  isActive  Boolean @default(true)

  // Business hours stored as JSON: { mon: ["09:00","23:00"], tue: ..., closed: ["sun"] }
  // Phase 2 ships fields as nullable; UI uses sensible defaults until edited.
  hoursJson Json?

  // Default tax / service charge rates as percentage * 100 (e.g. 1700 = 17.00%)
  taxBps     Int @default(0)
  serviceBps Int @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isPrimary])
}

model TenantMembership {
  id       String     @id @default(cuid())
  tenantId String
  userId   String
  role     TenantRole @default(OWNER)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

// ----------------------------- MENU ----------------------------------

model MenuCategory {
  id        String  @id @default(cuid())
  tenantId  String
  name      String
  nameUr    String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  photoUrl  String?

  // Optional scheduled availability — minutes from midnight, e.g. 420 = 07:00
  scheduledStartMin Int?
  scheduledEndMin   Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  MenuItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, sortOrder])
}

model MenuItem {
  id              String  @id @default(cuid())
  tenantId        String
  categoryId      String
  name            String
  nameUr          String?
  description     String?
  photoUrl        String?
  prepTimeMinutes Int     @default(10)
  isAvailable     Boolean @default(true)
  sortOrder       Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category       MenuCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variants       MenuVariant[]
  modifierGroups ModifierGroup[]

  @@index([tenantId])
  @@index([categoryId])
  @@index([tenantId, sortOrder])
}

model MenuVariant {
  id          String  @id @default(cuid())
  itemId      String
  name        String
  priceCents  Int
  isDefault   Boolean @default(false)
  isAvailable Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  item   MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  recipe Recipe?

  @@index([itemId])
}

model ModifierGroup {
  id        String  @id @default(cuid())
  itemId    String
  name      String
  required  Boolean @default(false)
  minSelect Int     @default(0)
  maxSelect Int     @default(1)
  sortOrder Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  item      MenuItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  modifiers Modifier[]

  @@index([itemId])
}

model Modifier {
  id              String  @id @default(cuid())
  groupId         String
  name            String
  priceDeltaCents Int     @default(0)
  isAvailable     Boolean @default(true)
  sortOrder       Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  group ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

// ----------------------------- INVENTORY -----------------------------

model Supplier {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  contactName String?
  phone       String?
  notes       String?
  isActive    Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ingredients Ingredient[]
  purchases   Purchase[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Ingredient {
  id           String         @id @default(cuid())
  tenantId     String
  name         String
  unit         IngredientUnit
  // Quantities use Decimal to avoid floating-point drift; up to 999,999,999.999
  currentStock Decimal        @default(0) @db.Decimal(12, 3)
  reorderLevel Decimal        @default(0) @db.Decimal(12, 3)
  // Average cost per 1 unit (e.g. cents per kg if unit=KG), in paisa.
  // Updated by weighted average on each PURCHASE movement.
  avgCostCents Int            @default(0)
  supplierId   String?
  isActive     Boolean        @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier       Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  recipeItems    RecipeItem[]
  stockMovements StockMovement[]
  purchaseItems  PurchaseItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([supplierId])
}

model Recipe {
  id              String  @id @default(cuid())
  variantId       String  @unique
  notes           String?
  // Cached cost-per-plate in paisa. Recomputed on edit & on ingredient avgCost change.
  cachedCostCents Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variant MenuVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  items   RecipeItem[]

  @@index([variantId])
}

model RecipeItem {
  id             String  @id @default(cuid())
  recipeId       String
  ingredientId   String
  // Quantity in the ingredient's unit, e.g. 0.150 kg.
  quantity       Decimal @db.Decimal(12, 3)
  // Optional wastage padding (e.g. 5 = 5% extra cost factored in).
  wastagePercent Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@unique([recipeId, ingredientId])
  @@index([recipeId])
  @@index([ingredientId])
}

model StockMovement {
  id            String              @id @default(cuid())
  tenantId      String
  branchId      String?
  ingredientId  String
  reason        StockMovementReason
  // Signed delta in the ingredient's unit. Positive for IN, negative for OUT.
  deltaQty      Decimal             @db.Decimal(12, 3)
  // Per-unit cost at the time of this movement (paisa).
  unitCostCents Int                 @default(0)
  notes         String?
  // Optional polymorphic ref so a movement can point to its source row.
  refType       String? // PURCHASE_ITEM | ORDER_ITEM | WASTAGE_LOG | STOCK_TAKE | ADJUSTMENT
  refId         String?
  wastageReason WastageReason?
  createdById   String?

  createdAt DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
  @@index([ingredientId, createdAt])
  @@index([tenantId, reason])
}

model Purchase {
  id           String  @id @default(cuid())
  tenantId     String
  branchId     String?
  supplierId   String?
  billNumber   String?
  billPhotoUrl String?
  totalCents   Int     @default(0)
  notes        String?

  purchasedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  createdById String?

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items    PurchaseItem[]

  @@index([tenantId, purchasedAt])
}

model PurchaseItem {
  id            String  @id @default(cuid())
  purchaseId    String
  ingredientId  String
  quantity      Decimal @db.Decimal(12, 3)
  unitCostCents Int

  purchase   Purchase   @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
}

// ----------------------------- BILLING -------------------------------

model Plan {
  id          String  @id @default(cuid())
  code        String  @unique // "trial" | "basic" | "pro" | "enterprise"
  name        String
  description String?
  priceCents  Int     @default(0) // monthly, in paisa (PKR) for local; cents for USD via Stripe
  currency    String  @default("PKR")

  maxBranches    Int     @default(1)
  maxStaff       Int     @default(5)
  whatsappEnabled Boolean @default(false)
  apiEnabled      Boolean @default(false)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id       String             @id @default(cuid())
  tenantId String             @unique
  planId   String
  status   SubscriptionStatus @default(TRIALING)

  trialEndsAt    DateTime?
  currentPeriodEnd DateTime?
  canceledAt     DateTime?

  stripeCustomerId     String?
  stripeSubscriptionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])

  @@index([status])
}

// ----------------------------- AUDIT ---------------------------------

model AuditLog {
  id        String      @id @default(cuid())
  tenantId  String?     // null = platform-level (super admin) action
  userId    String?     // actor; null for system actions
  action    AuditAction
  metadata  Json?       // free-form context (impersonation reason, etc.)
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
}
