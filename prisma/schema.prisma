// =====================================================================
// EasyMenu — Prisma schema (Phase 1)
// Multi-tenant: every tenant-scoped table has tenantId + createdAt/updatedAt/deletedAt.
// Future phases will extend this schema; do not break naming conventions.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------- ENUMS ---------------------------------

enum TenantRole {
  OWNER
  MANAGER
  CASHIER
  KITCHEN
  WAITER
  DELIVERY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
}

enum CuisineType {
  RESTAURANT
  CAFE
  FAST_FOOD
  BAKERY
  CLOUD_KITCHEN
  OTHER
}

enum AuditAction {
  TENANT_CREATED
  USER_CREATED
  USER_LOGIN
  USER_LOGOUT
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  ONBOARDING_COMPLETED
  IMPERSONATION_STARTED
  IMPERSONATION_ENDED
  TRIAL_EXTENDED
  SUBSCRIPTION_CHANGED
  SETTINGS_UPDATED
}

// ----------------------------- AUTH ----------------------------------
// NextAuth-compatible models (Account, Session, VerificationToken)

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------- USERS ---------------------------------

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null for pure-OAuth users
  isSuperAdmin  Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  accounts    Account[]
  sessions    Session[]
  memberships TenantMembership[]
  auditLogs   AuditLog[]

  @@index([email])
}

// ----------------------------- TENANTS -------------------------------

model Tenant {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  cuisineType CuisineType @default(RESTAURANT)
  contactPhone String?
  logoUrl      String?
  brandColor   String?

  // Tenant-wide config (kept here, not split into Settings table for Phase 1)
  currency     String  @default("PKR")
  timezone     String  @default("Asia/Karachi")
  locale       String  @default("en")
  hasDelivery  Boolean @default(false)
  hasTakeaway  Boolean @default(true)
  acceptCash   Boolean @default(true)
  acceptCard   Boolean @default(false)
  acceptJazzCash Boolean @default(false)
  acceptEasypaisa Boolean @default(false)
  acceptBankTransfer Boolean @default(false)

  onboardedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberships  TenantMembership[]
  subscription Subscription?
  categories   MenuCategorySeed[]
  auditLogs    AuditLog[]

  @@index([slug])
  @@index([deletedAt])
}

model TenantMembership {
  id       String     @id @default(cuid())
  tenantId String
  userId   String
  role     TenantRole @default(OWNER)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

// Phase 1 placeholder so onboarding step 3 can persist categories.
// Phase 2 will introduce full MenuCategory + MenuItem + Variant + Modifier models.
model MenuCategorySeed {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  sortOrder Int      @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ----------------------------- BILLING -------------------------------

model Plan {
  id          String  @id @default(cuid())
  code        String  @unique // "trial" | "basic" | "pro" | "enterprise"
  name        String
  description String?
  priceCents  Int     @default(0) // monthly, in paisa (PKR) for local; cents for USD via Stripe
  currency    String  @default("PKR")

  maxBranches    Int     @default(1)
  maxStaff       Int     @default(5)
  whatsappEnabled Boolean @default(false)
  apiEnabled      Boolean @default(false)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id       String             @id @default(cuid())
  tenantId String             @unique
  planId   String
  status   SubscriptionStatus @default(TRIALING)

  trialEndsAt    DateTime?
  currentPeriodEnd DateTime?
  canceledAt     DateTime?

  stripeCustomerId     String?
  stripeSubscriptionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])

  @@index([status])
}

// ----------------------------- AUDIT ---------------------------------

model AuditLog {
  id        String      @id @default(cuid())
  tenantId  String?     // null = platform-level (super admin) action
  userId    String?     // actor; null for system actions
  action    AuditAction
  metadata  Json?       // free-form context (impersonation reason, etc.)
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
}
