// =====================================================================
// EasyMenu — Prisma schema (Phase 1)
// Multi-tenant: every tenant-scoped table has tenantId + createdAt/updatedAt/deletedAt.
// Future phases will extend this schema; do not break naming conventions.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------- ENUMS ---------------------------------

enum TenantRole {
  OWNER
  MANAGER
  CASHIER
  KITCHEN
  WAITER
  DELIVERY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
  LIFETIME
}

enum PlanInterval {
  MONTH
  YEAR
  LIFETIME
}

enum CuisineType {
  RESTAURANT
  CAFE
  FAST_FOOD
  BAKERY
  CLOUD_KITCHEN
  OTHER
}

enum IngredientUnit {
  G
  KG
  ML
  L
  PCS
  DOZEN
}

enum StockMovementReason {
  PURCHASE
  SALE
  WASTAGE
  ADJUSTMENT
  STOCK_TAKE
}

enum WastageReason {
  SPOILAGE
  BREAKAGE
  THEFT
  TRAINING
  OTHER
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
  BILLING
}

enum OrderChannel {
  DINE_IN
  TAKEAWAY
  DELIVERY
  ONLINE
  WHATSAPP
}

enum OrderStatus {
  NEW
  PREPARING
  READY
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  JAZZCASH
  EASYPAISA
  BANK_TRANSFER
  SPLIT
}

enum PaymentVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  FAILED
}

enum DeliveryAssignmentStatus {
  ASSIGNED
  PICKED_UP
  DELIVERED
  RETURNED
  CANCELLED
}

enum DeliveryCashStatus {
  PENDING
  RECONCILED
  DISPUTED
}

enum WhatsAppThreadStatus {
  OPEN
  CLOSED
}

enum WhatsAppMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsAppMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum NotificationType {
  ORDER_CREATED
  ORDER_READY
  ORDER_OUT_FOR_DELIVERY
  ORDER_COMPLETED
  ORDER_CANCELLED
  LOW_STOCK
  WHATSAPP_MESSAGE
  DELIVERY_CASH_SUBMITTED
  PAYMENT_RECORDED
}

enum DealType {
  PERCENT_OFF     // e.g. 10% off any order
  FLAT_OFF        // e.g. Rs 100 off any order
  FREE_DELIVERY   // waive delivery charge
}

enum CouponType {
  PERCENT_OFF
  FLAT_OFF
  FREE_DELIVERY
}

enum AuditAction {
  TENANT_CREATED
  USER_CREATED
  USER_LOGIN
  USER_LOGOUT
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  ONBOARDING_COMPLETED
  IMPERSONATION_STARTED
  IMPERSONATION_ENDED
  TRIAL_EXTENDED
  SUBSCRIPTION_CHANGED
  SETTINGS_UPDATED
  BRANCH_CREATED
  BRANCH_UPDATED
  BRANCH_DELETED
  MENU_CATEGORY_CREATED
  MENU_CATEGORY_UPDATED
  MENU_CATEGORY_DELETED
  MENU_ITEM_CREATED
  MENU_ITEM_UPDATED
  MENU_ITEM_DELETED
  INGREDIENT_CREATED
  INGREDIENT_UPDATED
  INGREDIENT_DELETED
  SUPPLIER_CREATED
  SUPPLIER_UPDATED
  RECIPE_UPDATED
  STOCK_RECEIVED
  STOCK_WASTED
  STOCK_ADJUSTED
  TABLE_CREATED
  TABLE_UPDATED
  TABLE_DELETED
  ORDER_CREATED
  ORDER_STATUS_CHANGED
  ORDER_CANCELLED
  PAYMENT_RECORDED
  DELIVERY_ASSIGNED
  DELIVERY_PICKED_UP
  DELIVERY_COMPLETED
  DELIVERY_RETURNED
  DELIVERY_CASH_SUBMITTED
  DELIVERY_CASH_RECONCILED
  WHATSAPP_MESSAGE_SENT
  WHATSAPP_THREAD_CLOSED
  WHATSAPP_CONVERTED_TO_ORDER
}

// ----------------------------- AUTH ----------------------------------
// NextAuth-compatible models (Account, Session, VerificationToken)

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------- USERS ---------------------------------

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null for pure-OAuth users
  isSuperAdmin  Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  accounts             Account[]
  sessions             Session[]
  memberships          TenantMembership[]
  auditLogs            AuditLog[]
  deliveryAssignments  DeliveryAssignment[]
  deliveryCashEnvelopes DeliveryCashSubmission[]
  passwordResetTokens  PasswordResetToken[]

  @@index([email])
}

// One-time use, short-lived password reset tokens. The raw token is sent via
// email; only its sha256 hash is stored so a DB leak doesn't expose live links.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ----------------------------- TENANTS -------------------------------

model Tenant {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  cuisineType CuisineType @default(RESTAURANT)
  contactPhone String?
  logoUrl      String?
  brandColor   String?

  // Tenant-wide config (kept here, not split into Settings table for Phase 1)
  currency     String  @default("PKR")
  timezone     String  @default("Asia/Karachi")
  locale       String  @default("en")
  hasDelivery  Boolean @default(false)
  hasTakeaway  Boolean @default(true)
  acceptCash   Boolean @default(true)
  acceptCard   Boolean @default(false)
  acceptJazzCash Boolean @default(false)
  acceptEasypaisa Boolean @default(false)
  acceptBankTransfer Boolean @default(false)

  // Per-tenant WhatsApp toggle. Even when env WHATSAPP_ENABLED=true, the
  // tenant must explicitly opt in — turning this OFF stops webhook intake,
  // refuses outbound sends, and hides the inbox.
  whatsappEnabled Boolean @default(false)
  whatsappNumber  String?

  // Delivery service area — one or both can be set.
  // deliveryRadiusKm: circular radius from the primary branch (geodesic km).
  // deliveryAreas: allow-list of keywords matched in the address (case-insensitive).
  // Both null = no zone check (delivers anywhere hasDelivery is on).
  deliveryRadiusKm Decimal? @db.Decimal(5, 2)
  deliveryAreas    String[] @default([])
  deliveryFeeCents Int      @default(0)
  deliveryMinOrderCents Int @default(0)

  onboardedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberships         TenantMembership[]
  subscription        Subscription?
  branches            Branch[]
  menuCategories      MenuCategory[]
  menuItems           MenuItem[]
  ingredients         Ingredient[]
  suppliers           Supplier[]
  stockMovements      StockMovement[]
  purchases           Purchase[]
  tables              RestaurantTable[]
  customers           Customer[]
  orders              Order[]
  payments            Payment[]
  deliveryAssignments DeliveryAssignment[]
  deliveryCashEnvelopes DeliveryCashSubmission[]
  whatsappThreads     WhatsAppThread[]
  notifications       Notification[]
  deals               Deal[]
  coupons             Coupon[]
  reviews             Review[]
  auditLogs           AuditLog[]

  @@index([slug])
  @@index([deletedAt])
}

// ----------------------------- BRANCHES ------------------------------

model Branch {
  id        String  @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  phone     String?
  isPrimary Boolean @default(false)
  isActive  Boolean @default(true)

  // Business hours stored as JSON: { mon: ["09:00","23:00"], tue: ..., closed: ["sun"] }
  // Phase 2 ships fields as nullable; UI uses sensible defaults until edited.
  hoursJson Json?

  // Default tax / service charge rates as percentage * 100 (e.g. 1700 = 17.00%)
  taxBps     Int @default(0)
  serviceBps Int @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isPrimary])
}

model TenantMembership {
  id       String     @id @default(cuid())
  tenantId String
  userId   String
  role     TenantRole @default(OWNER)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

// ----------------------------- MENU ----------------------------------

model MenuCategory {
  id        String  @id @default(cuid())
  tenantId  String
  name      String
  nameUr    String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  photoUrl  String?

  // Optional scheduled availability — minutes from midnight, e.g. 420 = 07:00
  scheduledStartMin Int?
  scheduledEndMin   Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  MenuItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, sortOrder])
}

model MenuItem {
  id              String  @id @default(cuid())
  tenantId        String
  categoryId      String
  name            String
  nameUr          String?
  description     String?
  photoUrl        String?
  prepTimeMinutes Int     @default(10)
  isAvailable     Boolean @default(true)
  sortOrder       Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category       MenuCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variants       MenuVariant[]
  modifierGroups ModifierGroup[]

  @@index([tenantId])
  @@index([categoryId])
  @@index([tenantId, sortOrder])
}

model MenuVariant {
  id          String  @id @default(cuid())
  itemId      String
  name        String
  priceCents  Int
  isDefault   Boolean @default(false)
  isAvailable Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  item   MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  recipe Recipe?

  @@index([itemId])
}

model ModifierGroup {
  id        String  @id @default(cuid())
  itemId    String
  name      String
  required  Boolean @default(false)
  minSelect Int     @default(0)
  maxSelect Int     @default(1)
  sortOrder Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  item      MenuItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  modifiers Modifier[]

  @@index([itemId])
}

model Modifier {
  id              String  @id @default(cuid())
  groupId         String
  name            String
  priceDeltaCents Int     @default(0)
  isAvailable     Boolean @default(true)
  sortOrder       Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  group ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

// ----------------------------- INVENTORY -----------------------------

model Supplier {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  contactName String?
  phone       String?
  notes       String?
  isActive    Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ingredients Ingredient[]
  purchases   Purchase[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Ingredient {
  id           String         @id @default(cuid())
  tenantId     String
  name         String
  unit         IngredientUnit
  // Quantities use Decimal to avoid floating-point drift; up to 999,999,999.999
  currentStock Decimal        @default(0) @db.Decimal(12, 3)
  reorderLevel Decimal        @default(0) @db.Decimal(12, 3)
  // Average cost per 1 unit (e.g. cents per kg if unit=KG), in paisa.
  // Updated by weighted average on each PURCHASE movement.
  avgCostCents Int            @default(0)
  supplierId   String?
  isActive     Boolean        @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier       Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  recipeItems    RecipeItem[]
  stockMovements StockMovement[]
  purchaseItems  PurchaseItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([supplierId])
}

model Recipe {
  id              String  @id @default(cuid())
  variantId       String  @unique
  notes           String?
  // Cached cost-per-plate in paisa. Recomputed on edit & on ingredient avgCost change.
  cachedCostCents Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variant MenuVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  items   RecipeItem[]

  @@index([variantId])
}

model RecipeItem {
  id             String  @id @default(cuid())
  recipeId       String
  ingredientId   String
  // Quantity in the ingredient's unit, e.g. 0.150 kg.
  quantity       Decimal @db.Decimal(12, 3)
  // Optional wastage padding (e.g. 5 = 5% extra cost factored in).
  wastagePercent Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@unique([recipeId, ingredientId])
  @@index([recipeId])
  @@index([ingredientId])
}

model StockMovement {
  id            String              @id @default(cuid())
  tenantId      String
  branchId      String?
  ingredientId  String
  reason        StockMovementReason
  // Signed delta in the ingredient's unit. Positive for IN, negative for OUT.
  deltaQty      Decimal             @db.Decimal(12, 3)
  // Per-unit cost at the time of this movement (paisa).
  unitCostCents Int                 @default(0)
  notes         String?
  // Optional polymorphic ref so a movement can point to its source row.
  refType       String? // PURCHASE_ITEM | ORDER_ITEM | WASTAGE_LOG | STOCK_TAKE | ADJUSTMENT
  refId         String?
  wastageReason WastageReason?
  createdById   String?

  createdAt DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
  @@index([ingredientId, createdAt])
  @@index([tenantId, reason])
}

model Purchase {
  id           String  @id @default(cuid())
  tenantId     String
  branchId     String?
  supplierId   String?
  billNumber   String?
  billPhotoUrl String?
  totalCents   Int     @default(0)
  notes        String?

  purchasedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  createdById String?

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items    PurchaseItem[]

  @@index([tenantId, purchasedAt])
}

model PurchaseItem {
  id            String  @id @default(cuid())
  purchaseId    String
  ingredientId  String
  quantity      Decimal @db.Decimal(12, 3)
  unitCostCents Int

  purchase   Purchase   @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
}

// ----------------------------- TABLES --------------------------------
// "RestaurantTable" name avoids the SQL-reserved-word collision with "Table".

model RestaurantTable {
  id        String      @id @default(cuid())
  tenantId  String
  branchId  String
  label     String      // e.g. "T-1"
  seats     Int         @default(2)
  qrCode    String      @unique @default(cuid())
  status    TableStatus @default(FREE)
  positionX Int?        // canvas pos for floor plan (Phase 3)
  positionY Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([branchId, label])
  @@index([tenantId])
  @@index([branchId])
}

// ----------------------------- CUSTOMERS -----------------------------

model Customer {
  id              String   @id @default(cuid())
  tenantId        String
  phone           String
  name            String?
  totalOrders     Int      @default(0)
  totalSpentCents Int      @default(0)
  lastOrderAt     DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([tenantId, phone])
  @@index([tenantId])
}

// ----------------------------- ORDERS --------------------------------

model Order {
  id              String       @id @default(cuid())
  tenantId        String
  branchId        String
  channel         OrderChannel
  status          OrderStatus  @default(NEW)
  // Sequential per-tenant order number for receipts (e.g. "0042"). Set on create.
  orderNumber     Int

  tableId         String?
  customerId      String?
  customerPhone   String?
  customerName    String?
  deliveryAddress String?

  // All amounts in paisa (Int)
  subtotalCents       Int @default(0)
  taxCents            Int @default(0)
  serviceCents        Int @default(0)
  discountCents       Int @default(0)
  tipCents            Int @default(0)
  deliveryChargeCents Int @default(0)
  totalCents          Int @default(0)

  notes        String?
  // Idempotency key prevents duplicate POS submits (e.g. double-tap).
  idempotencyKey String? @unique
  // Coupon code applied at checkout (snapshot — coupon may be deleted later).
  appliedCouponCode String?
  createdById  String?
  // Customer user (NextAuth User) who placed this order via the public site.
  // NULL for walk-in POS orders or guest (unauthenticated) orders on table QR.
  customerUserId String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  cancelledAt DateTime?
  cancelReason String?

  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  table              RestaurantTable?  @relation(fields: [tableId], references: [id], onDelete: SetNull)
  customer           Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  payments           Payment[]
  statusLog          OrderStatusLog[]
  deliveryAssignment DeliveryAssignment?
  whatsappThread     WhatsAppThread?

  @@unique([tenantId, orderNumber])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([branchId, status])
  @@index([customerUserId])
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  menuItemId      String
  variantId       String
  // Snapshots so historical orders aren't affected by later menu edits.
  itemNameSnap    String
  variantNameSnap String
  unitPriceCents  Int
  quantity        Int
  notes           String?
  // Cached line total = quantity * (unitPriceCents + sum modifier deltas)
  lineTotalCents  Int     @default(0)

  createdAt DateTime @default(now())

  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  modifiers OrderItemModifier[]

  @@index([orderId])
}

model OrderItemModifier {
  id              String @id @default(cuid())
  orderItemId     String
  modifierId      String?
  modifierNameSnap String
  priceDeltaCents Int

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
}

model OrderStatusLog {
  id          String      @id @default(cuid())
  orderId     String
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  changedById String?
  notes       String?
  createdAt   DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

// ----------------------------- PAYMENTS ------------------------------

model Payment {
  id              String                    @id @default(cuid())
  tenantId        String
  orderId         String
  method          PaymentMethod
  amountCents     Int
  reference       String?
  screenshotUrl   String?
  verification    PaymentVerificationStatus @default(UNVERIFIED)
  recordedById    String?

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([orderId])
  @@index([verification])
}

// ----------------------------- DELIVERY -------------------------------

model DeliveryAssignment {
  id                 String                   @id @default(cuid())
  tenantId           String
  orderId            String                   @unique
  deliveryUserId     String
  status             DeliveryAssignmentStatus @default(ASSIGNED)
  // Cash actually handed over by customer, in paisa. 0 if prepaid online.
  collectedCashCents Int                      @default(0)
  // Link to a DeliveryCashSubmission once the rider drops the envelope.
  cashSubmissionId   String?
  notes              String?

  assignedAt   DateTime  @default(now())
  pickedUpAt   DateTime?
  deliveredAt  DateTime?
  returnedAt   DateTime?
  returnReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order          Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliveryUser   User                    @relation(fields: [deliveryUserId], references: [id])
  cashSubmission DeliveryCashSubmission? @relation(fields: [cashSubmissionId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([deliveryUserId, status])
  @@index([tenantId, assignedAt])
}

model DeliveryCashSubmission {
  id              String             @id @default(cuid())
  tenantId        String
  deliveryUserId  String
  totalCents      Int
  status          DeliveryCashStatus @default(PENDING)
  notes           String?
  reconcileNotes  String?
  reconciledById  String?

  submittedAt  DateTime  @default(now())
  reconciledAt DateTime?

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveryUser User                 @relation(fields: [deliveryUserId], references: [id])
  assignments  DeliveryAssignment[]

  @@index([tenantId, submittedAt])
  @@index([deliveryUserId, status])
}

// ----------------------------- WHATSAPP ------------------------------

model WhatsAppThread {
  id               String               @id @default(cuid())
  tenantId         String
  customerPhone    String
  customerName     String?
  lastMessageAt    DateTime             @default(now())
  unreadCount      Int                  @default(0)
  status           WhatsAppThreadStatus @default(OPEN)
  // Once a thread is converted to an order, we keep a pointer both ways.
  convertedOrderId String?              @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages       WhatsAppMessage[]
  convertedOrder Order?           @relation(fields: [convertedOrderId], references: [id], onDelete: SetNull)

  @@unique([tenantId, customerPhone])
  @@index([tenantId, status])
  @@index([tenantId, lastMessageAt])
}

model WhatsAppMessage {
  id                String                   @id @default(cuid())
  threadId          String
  direction         WhatsAppMessageDirection
  body              String                   @db.Text
  mediaUrl          String?
  status            WhatsAppMessageStatus    @default(PENDING)
  providerMessageId String?
  sentByUserId      String?
  readAt            DateTime?

  createdAt DateTime @default(now())

  thread WhatsAppThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

// ----------------------------- DEALS ---------------------------------

model Deal {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  subtitle    String?
  // e.g. 1000 means 10.00% for PERCENT_OFF
  percentBps  Int?
  // FLAT_OFF amount in paisa
  flatOffCents Int?
  minOrderCents Int    @default(0)
  type        DealType
  heroImageUrl String?
  // Optional hex color override for banner background (defaults to brand)
  bgColor     String?
  ctaLabel    String?  // e.g. "Order now"
  // Scheduling — null endAt = runs indefinitely
  startsAt    DateTime @default(now())
  endsAt      DateTime?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@index([tenantId, sortOrder])
}

// ----------------------------- COUPONS -------------------------------

model Coupon {
  id               String     @id @default(cuid())
  tenantId         String
  // User-facing code, normalized to uppercase server-side.
  code             String
  type             CouponType
  // For PERCENT_OFF: percentBps (1000 = 10.00%)
  percentBps       Int?
  // For FLAT_OFF: flatOffCents
  flatOffCents     Int?
  // Cap on the discount amount applied (useful for percent coupons on huge orders).
  maxDiscountCents Int?
  // Order subtotal must be at least this much for the coupon to apply.
  minOrderCents    Int        @default(0)
  // Total redemptions across all customers; null = unlimited.
  maxRedemptions   Int?
  // Denormalized counter — updated atomically inside the order transaction.
  redemptionsCount Int        @default(0)
  validFrom        DateTime   @default(now())
  validUntil       DateTime?
  isActive         Boolean    @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  redemptions CouponRedemption[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model CouponRedemption {
  id            String   @id @default(cuid())
  couponId      String
  tenantId      String
  // One redemption per order.
  orderId       String   @unique
  discountCents Int
  createdAt     DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([couponId])
}

// ----------------------------- REVIEWS -------------------------------

model Review {
  id        String  @id @default(cuid())
  tenantId  String
  // The logged-in customer who wrote this review.
  userId    String
  // Optional link to the order that prompted this review.
  orderId   String?
  // 1..5 stars
  rating    Int
  title     String?
  body      String?
  // Moderation — tenant can hide abusive / off-topic reviews.
  isHidden  Boolean @default(false)
  // Owner / manager can leave a single public reply.
  ownerReply   String?
  ownerRepliedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, orderId])
  @@index([tenantId, isHidden, createdAt])
  @@index([userId])
}

// ----------------------------- NOTIFICATIONS --------------------------

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  // userId == null means "for any staff who can see this tenant" —
  // broadcast notifications (new order, low stock). When set, scoped
  // to a specific user.
  userId    String?
  type      NotificationType
  title     String
  body      String?
  // Optional deep link to jump to the relevant page.
  href      String?
  metadata  Json?
  readAt    DateTime?

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, userId, readAt])
}

// ----------------------------- BILLING -------------------------------

model Plan {
  id          String       @id @default(cuid())
  code        String       @unique // "starter" | "growth" | "enterprise" | "lifetime"
  name        String
  tagline     String?
  description String?
  // Sort on pricing page, lowest tier first.
  sortOrder   Int          @default(0)
  // MONTH / YEAR / LIFETIME. LIFETIME plans ignore renewsAt.
  interval    PlanInterval @default(MONTH)
  priceCents  Int          @default(0)
  currency    String       @default("PKR")
  // "Old" price shown struck-through for urgency marketing (optional).
  compareAtPriceCents Int? @default(0)

  // Feature limits / flags — customers compare these on pricing page.
  maxBranches    Int     @default(1)
  maxStaff       Int     @default(5)
  maxMenuItems   Int     @default(50)
  maxMonthlyOrders Int   @default(500)
  whatsappEnabled Boolean @default(false)
  deliveryZonesEnabled Boolean @default(false)
  customDomainEnabled Boolean @default(false)
  prioritySupport Boolean @default(false)
  apiEnabled      Boolean @default(false)

  // Public visibility + marketing
  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)
  isPublic   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@index([isActive, sortOrder])
}

model Subscription {
  id       String             @id @default(cuid())
  tenantId String             @unique
  planId   String
  status   SubscriptionStatus @default(TRIALING)

  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  canceledAt       DateTime?
  // For LIFETIME purchases we still record when paid for auditability.
  lifetimePurchasedAt DateTime?

  stripeCustomerId     String?
  stripeSubscriptionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan     Plan            @relation(fields: [planId], references: [id])
  invoices PlanInvoice[]

  @@index([status])
}

// Records of every payment made by a tenant for their plan — monthly renewal,
// lifetime purchase, upgrade, manual bank transfer, etc. One row per payment.
model PlanInvoice {
  id              String   @id @default(cuid())
  subscriptionId  String
  tenantId        String
  planCode        String
  periodStart     DateTime
  periodEnd       DateTime?
  amountCents     Int
  currency        String   @default("PKR")
  method          String // "CARD", "CASH", "JAZZCASH", "EASYPAISA", "BANK", "MANUAL"
  status          String   @default("PENDING") // "PENDING" | "PAID" | "FAILED" | "REFUNDED"
  reference       String? // external txn id / bank reference
  screenshotUrl   String? // for manual bank transfer verification
  approvedById    String? // super-admin user who approved a manual payment
  approvedAt      DateTime?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([subscriptionId])
  @@index([status])
}

// ----------------------------- AUDIT ---------------------------------

model AuditLog {
  id        String      @id @default(cuid())
  tenantId  String?     // null = platform-level (super admin) action
  userId    String?     // actor; null for system actions
  action    AuditAction
  metadata  Json?       // free-form context (impersonation reason, etc.)
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
}
